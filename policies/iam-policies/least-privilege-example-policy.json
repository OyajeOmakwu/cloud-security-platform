{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadSpecificBucketOnly",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::example-logs-bucket",
        "arn:aws:s3:::example-logs-bucket/*"
      ]
    }
  ]
}
